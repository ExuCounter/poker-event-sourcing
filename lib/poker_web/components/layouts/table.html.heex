<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Poker" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Bodoni+Moda:ital,wght@0,500;0,700;1,500&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    <div id="page-loading" class="fixed inset-0 z-[9999] bg-[var(--pkr-bg-0)] flex items-center justify-center flex-col gap-4">
      <svg class="animate-spin h-7 w-7 text-[var(--pkr-accent)]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.568 3 7.291l3-3z"></path>
      </svg>
      <span class="font-[family-name:var(--pkr-font-mono)] text-[11px] uppercase tracking-[0.12em] text-[var(--pkr-ink-3)]">Loading</span>
    </div>
    <div class="absolute left-0 top-0 w-full z-10">
      <div class="flex items-center justify-between border-b border-[var(--pkr-line)] bg-black/40 backdrop-blur-lg font-[family-name:var(--pkr-font-ui)]" style="transform: scale(var(--ui-scale, 0)); width: calc(100vw / var(--ui-scale, 1)); transform-origin: 0 0">
        <!-- Left Navigation -->
        <div class="flex items-center gap-3 pl-5 py-3">
          <.link
            href={@lobby_path}
            class="font-[family-name:var(--pkr-font-mono)] text-xs text-[var(--pkr-ink-3)] hover:text-[var(--pkr-ink-2)] px-3 py-1.5 rounded-md border border-transparent hover:border-[var(--pkr-line)] transition-all"
          >
            <span class="flex items-center gap-2">
              <span class="text-sm">&larr;</span>
              Lobby
            </span>
          </.link>

          <div class="w-px h-4 bg-[var(--pkr-line)]"></div>

          <%= if assigns[:replay] do %>
            <.link
              href={~p"/tables/#{@table_id}/game"}
              class="font-[family-name:var(--pkr-font-mono)] text-xs text-[var(--pkr-ink-3)] hover:text-[var(--pkr-ink-2)] px-3 py-1.5 rounded-md border border-transparent hover:border-[var(--pkr-line)] transition-all"
            >
              <span class="flex items-center gap-2">
                <span class="text-sm">&larr;</span>
                Back to Game
              </span>
            </.link>
          <% else %>
            <.link
              href={~p"/tables/#{@table_id}/replay"}
              target="_blank"
              class="font-[family-name:var(--pkr-font-mono)] text-xs text-[var(--pkr-ink-3)] hover:text-[var(--pkr-ink-2)] px-3 py-1.5 rounded-md border border-transparent hover:border-[var(--pkr-line)] transition-all"
            >
              <span class="flex items-center gap-2">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Replay
              </span>
            </.link>
          <% end %>
        </div>

        <!-- Right Navigation -->
        <div class="flex items-center gap-2 pr-5 py-3">
          <.link
            href={~p"/users/settings"}
            class="px-3 py-1.5 rounded-md text-xs text-[var(--pkr-ink-2)] border border-[var(--pkr-line)] hover:bg-[var(--pkr-bg-2)] hover:text-[var(--pkr-ink-1)] transition-all cursor-pointer"
          >
            Settings
          </.link>

          <%= if assigns[:is_participant] do %>
            <button
              phx-click="leave_table"
              data-confirm="Are you sure you want to leave the table? Your chips will be returned to your balance."
              class="px-3 py-1.5 rounded-md text-xs text-[var(--pkr-danger)] border border-[var(--pkr-danger)]/40 hover:bg-[var(--pkr-danger)]/15 transition-all cursor-pointer"
            >
              Leave
            </button>
          <% else %>
            <.link
              href={~p"/users/log-out"}
              method="delete"
              class="px-3 py-1.5 rounded-md text-xs text-[var(--pkr-danger)] border border-[var(--pkr-danger)]/40 hover:bg-[var(--pkr-danger)]/15 transition-all cursor-pointer"
            >
              Log out
            </.link>
          <% end %>
        </div>
      </div>
    </div>
    {@inner_content}
  </body>
</html>
